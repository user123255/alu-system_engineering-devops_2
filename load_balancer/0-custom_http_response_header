#!/bin/bash
# 0-custom_http_response_header - configure Nginx with custom header X-Served-By

# Install Nginx if not installed
if ! command -v nginx &> /dev/null
then
    echo "[*] Installing Nginx..."
    sudo apt update && sudo apt install -y nginx
fi

# Set the hostname (replace STUDENT_ID with your ALU student ID)
sudo hostnamectl set-hostname <STUDENT_ID>-web-$(echo $HOSTNAME | grep -oE '[0-9]+$' || echo "01")

# Create Nginx config with custom header
cat <<EOF | sudo tee /etc/nginx/conf.d/custom_header.conf
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;

    server_name _;

    add_header X-Served-By \$hostname;

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF

# Remove default config to avoid conflict
sudo rm -f /etc/nginx/sites-enabled/default

# Test and restart Nginx
sudo nginx -t && sudo systemctl restart nginx

echo "[+] Nginx configured with X-Served-By: $(hostname)"

