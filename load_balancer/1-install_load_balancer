#!/usr/bin/env bash

# Install HAProxy
apt-get update -y
apt-get install -y haproxy

# Configure HAProxy
cat > /etc/haproxy/haproxy.cfg << 'EOF'
global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend http_front
    bind *:80
    default_backend http_back

backend http_back
    balance roundrobin
    server web-01 3.82.222.41:80 check
    server web-02 54.196.19.105:80 check
EOF

# Enable HAProxy
service haproxy restart
