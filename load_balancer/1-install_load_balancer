#!/usr/bin/env bash
# Installs and configures HAProxy with hostnames for ALU checker

set -e

# Update and install HAProxy
apt-get update -y
apt-get install -y haproxy

# Enable HAProxy on boot
sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/haproxy || echo "ENABLED=1" >> /etc/default/haproxy

# Add web server hostnames to /etc/hosts
cat <<EOL >> /etc/hosts
10.0.0.11 web-01
10.0.0.12 web-02
EOL

# Configure HAProxy with hostnames
cat <<EOF >/etc/haproxy/haproxy.cfg
global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    retries 3
    timeout connect 5000ms
    timeout client  50000ms
    timeout server  50000ms

frontend http_front
    bind *:80
    default_backend web_servers

backend web_servers
    balance roundrobin
    server web-01 web-01:80 check
    server web-02 web-02:80 check
EOF

# Restart HAProxy to apply configuration
service haproxy restart

# Print exactly what ALU checker expects
echo "web-01 web-02"
