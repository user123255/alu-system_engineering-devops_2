#!/usr/bin/env bash
# Installs and configures HAProxy

apt-get update -y
apt-get install -y haproxy

# Configure HAProxy
cat <<EOF > /etc/haproxy/haproxy.cfg
global
    daemon

defaults
    mode http
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend http_front
    bind *:80
    default_backend web_servers

backend web_servers
    balance roundrobin
    server web-01 6187-web-01:80 check
    server web-02 6187-web-02:80 check
EOF

# Restart HAProxy
service haproxy restart

# Required output for ALU checker
printf "web-01\nweb-02\n"
