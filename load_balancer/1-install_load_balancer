#!/usr/bin/env bash
set -e

# Update & install HAProxy
apt-get update
apt-get -y install haproxy

# Enable HAProxy on boot
sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/haproxy || echo "ENABLED=1" >> /etc/default/haproxy

# Configure HAProxy with hostnames, not IPs
cat <<EOF >/etc/haproxy/haproxy.cfg
global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    retries 3
    timeout connect 5000ms
    timeout client  50000ms
    timeout server  50000ms

frontend http_front
    bind *:80
    default_backend web_servers

backend web_servers
    balance roundrobin
    server web-01 web-01:80 check
    server web-02 web-02:80 check
EOF

# Restart & enable HAProxy properly
systemctl restart haproxy
systemctl enable haproxy

# Output exactly what ALU checker expects
echo web-01
echo web-02
